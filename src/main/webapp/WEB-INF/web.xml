<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Smart Inventory Control System</display-name>

    <!-- Welcome File List -->
    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>

    <!-- Session Filter for Demo Mode -->
    <filter>
        <filter-name>SessionFilter</filter-name>
        <filter-class>com.smartinventory.servlet.SessionFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>SessionFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Servlets Configuration -->

    <!-- Authentication Servlet -->
    <servlet>
        <servlet-name>AuthServlet</servlet-name>
        <servlet-class>com.smartinventory.servlet.AuthServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AuthServlet</servlet-name>
        <url-pattern>/auth/*</url-pattern>
    </servlet-mapping>

    <!-- Product Management Servlet -->
    <servlet>
        <servlet-name>ProductServlet</servlet-name>
        <servlet-class>com.smartinventory.servlet.ProductServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProductServlet</servlet-name>
        <url-pattern>/products/*</url-pattern>
    </servlet-mapping>

    <!-- Transactions (Stock In/Out) Servlet -->
    <servlet>
        <servlet-name>TransactionServlet</servlet-name>
        <servlet-class>com.smartinventory.servlet.TransactionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TransactionServlet</servlet-name>
        <url-pattern>/transactions/*</url-pattern>
    </servlet-mapping>

    <!-- Stock Sales / Billing Servlet -->
    <servlet>
        <servlet-name>StockSalesServlet</servlet-name>
        <servlet-class>com.smartinventory.servlet.StockSalesServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StockSalesServlet</servlet-name>
        <url-pattern>/stock-sales/*</url-pattern>
    </servlet-mapping>

    <!-- Alert / Notification Servlet -->
    <servlet>
        <servlet-name>AlertServlet</servlet-name>
        <servlet-class>com.smartinventory.servlet.AlertServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AlertServlet</servlet-name>
        <url-pattern>/alerts/*</url-pattern>
    </servlet-mapping>

    <!-- Report Generation Servlet -->
    <servlet>
        <servlet-name>ReportServlet</servlet-name>
        <servlet-class>com.smartinventory.servlet.ReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReportServlet</servlet-name>
        <url-pattern>/reports/*</url-pattern>
    </servlet-mapping>

    <!-- Alert Scheduler & Background Process Listener -->
    <listener>
        <listener-class>com.smartinventory.service.AlertScheduler</listener-class>
    </listener>

    <!-- Session Configuration -->
    <session-config>
        <session-timeout>30</session-timeout> <!-- minutes -->
    </session-config>

</web-app>
